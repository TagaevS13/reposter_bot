TELEGRAM_BOT_TOKEN=
TELEGRAM_CHANNEL_ID=@your_channel_or_chat_id

INSTAGRAM_USERNAME=
INSTAGRAM_PASSWORD=
INSTAGRAM_VERIFICATION_CODE=
INSTAGRAM_SESSION_PATH=.instagram_session.json
# Also attempt IG -> FB cross-post during feed publish (requires linked accounts in Meta).
INSTAGRAM_SHARE_TO_FACEBOOK=1

TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
TIKTOK_ACCESS_TOKEN=
TIKTOK_OPEN_ID=
TIKTOK_REDIRECT_URI=http://localhost:3000/callback
TIKTOK_OAUTH_SCOPE=user.info.profile,user.info.stats,video.list,video.upload,video.publish

# Private mode: comma separated Telegram user IDs allowed to use bot.
# Leave empty to allow everyone.
ALLOWED_USER_IDS=
# Optional: comma separated Telegram usernames (with or without @)
ALLOWED_USERNAMES=

# Prevent accidental second start of same bot process.
SINGLE_INSTANCE_LOCK_FILE=.runtime/repost-bot.lock
SINGLE_INSTANCE_LOCK_TIMEOUT_SECONDS=1

# Shared lock for IG publishing across private projects.
INSTAGRAM_GLOBAL_LOCK_FILE=C:/Users/ADMIN/.runtime/instagram-publish.lock
INSTAGRAM_GLOBAL_LOCK_TIMEOUT_SECONDS=300
